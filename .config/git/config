; vim:ft=gitconfig
[include]
	path = config.local
[core]
	pager = delta
	safecrlf = warn
[fetch]
	prune = true
[pull]
	rebase = true
[push]
	autoSetupRemote = true
	default = upstream
[column]
	ui = auto
[branch]
	sort = -committerdate
[rebase]
	autoSquash = true
[alias]
	cobra = !git --git-dir=$HOME/.cobra --work-tree=$HOME
	dog = log --decorate --oneline --graph
	adog = log --all --decorate --oneline --graph
	pfush = push --force-with-lease
[delta]
	side-by-side = true
	hyperlinks = true
